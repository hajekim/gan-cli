# Google Cloud Configuration
export GOOGLE_CLOUD_PROJECT="YOUR_PROJECT_ID"
export GOOGLE_CLOUD_LOCATION="global"
export GOOGLE_GENAI_USE_VERTEXAI=TRUE

# Claude 4.6 Sonnet (Vertex AI) Configuration
# Documentation: https://docs.cloud.google.com/vertex-ai/generative-ai/docs/partner-models/claude/sonnet-4-6
CLAUDE_MODEL_ID="claude-4-6-sonnet@20260415" # Check latest version if necessary
CLAUDE_REGION="global"

# Gemini Evaluator Configuration
# Gemini CLI will use the default model (Gemini 2.0 Pro with Thinking Mode)
GEMINI_EVAL_MODEL="gemini-2.0-pro-exp-02-05"
THINKING_BUDGET=16000 # High budget for skeptical evaluation
